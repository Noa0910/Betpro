# Copia a .env en local (opcional). En Vercel: Project Settings → Environment Variables

# Obligatorio en Vercel (sesiones seguras)
BETPRO_SECRET=cambia-esto-por-un-texto-largo-aleatorio

# Admin inicial (solo si la base de datos está vacía)
BETPRO_ADMIN_USER=admin
BETPRO_ADMIN_PASSWORD=cambia-esta-contraseña
BETPRO_ADMIN_NAME=Administrador BetPro

# === PRODUCCIÓN VERCEL (obligatorio para datos persistentes) ===
# Crear gratis en https://turso.tech
TURSO_DATABASE_URL=libsql://tu-db-nombre-usuario.turso.io
TURSO_AUTH_TOKEN=tu-token-de-turso

# Ruta SQLite local (solo desarrollo). No usar en Vercel.
# BETPRO_DB_PATH=C:\Datos\Betpro\betpro.db
